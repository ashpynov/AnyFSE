    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug AnyFSE Launcher",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "AnyFSE.exe",
            "args": ["anyfse://launcher"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build/Debug",
            "environment": [],
            "preLaunchTask": "Build AnyFSE Debug"
        },
        {
            "name": "Debug AnyFSE Settings",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "AnyFSE.exe",
            "args": ["/settings"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build/Debug",
            "environment": [],
            "preLaunchTask": "Build AnyFSE Debug"
        },
        {
            "name": "Debug AnyFSE AllyHid",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "AnyFSE.exe",
            "args": ["/allyhid"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build/Debug",
            "environment": [],
            "preLaunchTask": "Build AnyFSE Debug"
        },
        {
            "name": "Debug AnyFSE FSE Now",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "AnyFSE.exe",
            "args": ["/fse-now"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build/Debug",
            "environment": [],
            "preLaunchTask": "Build AnyFSE Debug"
        },
        {
            "name": "Debug with Coverage",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/Debug/AnyFSE.exe",
            "args": ["settings"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "console": "integratedTerminal",
            "preLaunchTask": "Build AnyFSE Debug"
        },
        {
            "name": "Debug AnyFSE.Installer",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "AnyFSE.Installer.exe",
            "args": [""],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build/Debug",
            "environment": [],
            "preLaunchTask": "Build AnyFSE.Installer Debug"
        },
        {
            "name": "Debug Uninstaller",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "unins000.exe",
            "args": ["/s", "/u"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/bin/Debug",
            "environment": [],
            "preLaunchTask": "Build AnyFSE.Uninstaller Debug"
        }
    ]
}