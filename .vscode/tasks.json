{
    "version": "2.0.0",
    "windows": {
        "options": {
            "shell": {
                "executable": "cmd.exe",
                "args": [
                    "/C",
                    // The path to VsDevCmd.bat depends on the version of Visual Studio you have installed.
                    "\"C:\\Program Files\\Microsoft Visual Studio\\2022\\Community\\Common7\\Tools\\VsDevCmd.bat\"",
                    "&&"
                ]
            }
        }
    },
    "tasks": [
        {
            "type": "shell",
            "label": "Build AnyFSE Release",
            "command": "msbuild.exe",
            "args": [
                "AnyFSE.sln",
                "-property:Configuration=Release",
                "-property:Platform=x64",
                "-target:Clean;AnyFSE;AnyFSE_Settings"
            ],
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "type": "shell",
            "label": "Clean Debug",
            "command": "msbuild.exe",
            "args": [
                "AnyFSE.sln",
                "-property:Configuration=Debug",
                "-property:Platform=x64",
                "-target:Clean"
            ],
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "type": "shell",
            "label": "Build AnyFSE Debug",
            "command": "msbuild.exe",
            "args": [
                "AnyFSE.sln",
                "-property:Configuration=Debug",
                "-property:Platform=x64",
                "-target:AnyFSE;AnyFSE_Settings"
            ],
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Package",
            "type": "shell",
            "command": "msbuild",
            "args": [
                "${workspaceFolder}/AnyFSE.sln",
                "/p:Configuration=Release",
                "/p:Platform=x64"
            ],
            "group": "build"
        }
    ]
}